# ── Anthropic API ──
# 必填。Anthropic API 密钥，用于调用 Claude 模型生成教程内容。
ANTHROPIC_API_KEY=

# 可选。自定义 API 基础地址（用于代理或兼容接口）。
# 留空则使用 Anthropic 官方地址 https://api.anthropic.com
# ANTHROPIC_BASE_URL=

# ── 模型选择 ──
# 可选。默认使用的模型档位：haiku / sonnet / opus。
# 也可直接填写完整的模型 ID（如 claude-sonnet-4-6-20250514）。
# 默认值：sonnet
# GRIMOIRE_MODEL=sonnet

# 可选。覆盖各档位对应的实际模型 ID：
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6-20250514
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6-20250514

# ── 详细模式 ──
# 可选。启用后每节输出更长、更详尽的教程内容。
# 设为 true / 1 / yes 启用，默认关闭。
# VERBOSE_MODE=true

# ── 并发控制 ──
# 可选。批量生成时的最大并发章节数。
# 默认值：4
# MAX_CONCURRENT_CHAPTERS=4
